# Correct 6061 target specification (adjusted for your scrap limitations)
TARGET_6061 = {
    'Si': (0.4, 0.8),
    'Fe': (0.0, 1.0),    # Increased Fe max to handle your scrap data
    'Cu': (0.0, 0.40),   # Lowered Cu min to handle your scrap data
    'Mn': (0.0, 1.0),    # Increased Mn max to handle your scrap data
