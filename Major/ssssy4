ELEMENTS = ['Si', 'Fe', 'Cu', 'Mn', 'Mg', 'Cr', 'Zn', 'Ti']


def check_6061_compliance(composition):
    """Check if composition meets adjusted 6061 specifications"""
    violations = []
    all_ok = True
    
    for elem, (min_val, max_val) in TARGET_6061.items():
        val = composition[elem]
        if val < min_val:
            violations.append((elem, val, min_val, max_val, 'LOW'))
            all_ok = False
        elif val > max_val:
            violations.append((elem, val, min_val, max_val, 'HIGH'))
            all_ok = False
    
    return all_ok, violations


def calculate_composition_score(composition):
    """Calculate how close composition is to ideal 6061 center"""
    score = 0
    for elem in ELEMENTS:
        min_val, max_val = TARGET_6061[elem]
        center = (min_val + max_val) / 2
        range_size = max_val - min_val if max_val > min_val else 0.1
        
        val = composition[elem]
        
        if val < min_val:
            score += ((min_val - val) / range_size * 100) ** 2
        elif val > max_val:
            score += ((val - max_val) / range_size * 100) ** 2
        else:
            score += ((val - center) / range_size * 10) ** 2
    
    return score


def calculate_mixed_composition(ingot_fraction, other_fractions):
    """Calculate final composition from AA6061-I + other scraps"""
    composition = {elem: 0.0 for elem in ELEMENTS}
    
    # Add AA6061-I contribution
    for elem in ELEMENTS:
        composition[elem] += SCRAP_MATERIALS['AA6061-I'][elem] * ingot_fraction
    
    # Add other scrap contributions
    for material, fraction in other_fractions.items():
        for elem in ELEMENTS:
            composition[elem] += SCRAP_MATERIALS[material][elem] * fraction
    
    return composition


def optimize_remaining_scrap(ingot_fraction, target_weight=100):
    """Find optimal combination of other 8 scraps for remaining fraction"""
    remaining_fraction = 1.0 - ingot_fraction
    
    solutions = []
    other_scraps = [name for name in SCRAP_MATERIALS.keys() if name != 'AA6061-I']
    
    # Test all possible combinations with finer splits
    print(f"    Testing all combinations...")
    
    # Try single scrap
    for scrap in other_scraps:
        other_fractions = {scrap: remaining_fraction}
        composition = calculate_mixed_composition(ingot_fraction, other_fractions)
        compliant, violations = check_6061_compliance(composition)
        
        solutions.append({
            'other_materials': other_fractions,
            'composition': composition,
            'compliant': compliant,
            'violations': violations,
            'violation_count': len(violations),
            'comp_score': calculate_composition_score(composition)
        })
    
    # Try two scrap combinations with finer splits
    for scrap1, scrap2 in combinations(other_scraps, 2):
        for split in np.arange(0.05, 1.0, 0.025):
            frac1 = remaining_fraction * split
            frac2 = remaining_fraction * (1 - split)
            
            other_fractions = {scrap1: frac1, scrap2: frac2}
            composition = calculate_mixed_composition(ingot_fraction, other_fractions)
            compliant, violations = check_6061_compliance(composition)
            
            solutions.append({
                'other_materials': other_fractions,
                'composition': composition,
                'compliant': compliant,
                'violations': violations,
                'violation_count': len(violations),
                'comp_score': calculate_composition_score(composition)
            })
    
    # Try three scrap combinations
    for combo in combinations(other_scraps, 3):
        for s1 in np.arange(0.1, 0.9, 0.1):
            for s2 in np.arange(0.1, 0.9 - s1, 0.1):
                s3 = 1.0 - s1 - s2
                if s3 >= 0.05:
                    other_fractions = {
                        combo[0]: remaining_fraction * s1,
                        combo[1]: remaining_fraction * s2,
                        combo[2]: remaining_fraction * s3
                    }
                    
                    composition = calculate_mixed_composition(ingot_fraction, other_fractions)
                    compliant, violations = check_6061_compliance(composition)
                    
                    solutions.append({
                        'other_materials': other_fractions,
                        'composition': composition,
                        'compliant': compliant,
                        'violations': violations,
                        'violation_count': len(violations),
                        'comp_score': calculate_composition_score(composition)
                    })
    
    # Filter out duplicates and sort
    unique_solutions = []
    seen_compositions = set()
    
    for sol in solutions:
        # Create a unique key for composition
        comp_key = tuple(round(sol['composition'][elem], 3) for elem in ELEMENTS)
        if comp_key not in seen_compositions:
            seen_compositions.add(comp_key)
            unique_solutions.append(sol)
    
    # Sort solutions
    compliant_solutions = [s for s in unique_solutions if s['compliant']]
    non_compliant_solutions = [s for s in unique_solutions if not s['compliant']]
    
    compliant_solutions.sort(key=lambda x: x['comp_score'])
    non_compliant_solutions.sort(key=lambda x: (x['violation_count'], x['comp_score']))
    
    return compliant_solutions, non_compliant_solutions


